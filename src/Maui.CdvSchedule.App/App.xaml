<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Maui.CdvSchedule.App.Presentation.Converters"
             x:Class="Maui.CdvSchedule.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <converters:StringHasValueConverter x:Key="StringHasValueConverter" />

            <!-- Runtime fallback values before Shared.Theming applies semantic resources. -->
            <Color x:Key="AppBackgroundColor">#FAFAFA</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceAltColor">#EEEEEE</Color>
            <Color x:Key="CardColor">#EEEEEE</Color>
            <Color x:Key="TextPrimaryColor">#000000</Color>
            <Color x:Key="TextMutedColor">#616161</Color>
            <Color x:Key="AccentColor">#2196F3</Color>
            <Color x:Key="AccentContrastColor">#FFFFFF</Color>
            <Color x:Key="BorderColor">#D0D0D0</Color>
            <Color x:Key="DangerColor">#FF0000</Color>
            <Color x:Key="TabBarBackgroundColor">#FFFFFF</Color>
            <Color x:Key="TabBarSelectedColor">#2196F3</Color>
            <Color x:Key="TabBarUnselectedColor">#777777</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
