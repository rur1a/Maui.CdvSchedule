<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Maui.CdvSchedule.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{DynamicResource SurfaceColor}"
    Shell.ForegroundColor="{DynamicResource TextPrimaryColor}"
    Shell.TitleColor="{DynamicResource TextPrimaryColor}"
    Shell.TabBarBackgroundColor="{DynamicResource TabBarBackgroundColor}"
    Shell.TabBarForegroundColor="{DynamicResource TabBarSelectedColor}"
    Shell.TabBarTitleColor="{DynamicResource TabBarSelectedColor}"
    Shell.TabBarUnselectedColor="{DynamicResource TabBarUnselectedColor}" />
